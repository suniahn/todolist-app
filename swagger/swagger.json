              }
            }
          },
          "500": { "$ref": "#/components/responses/500InternalError" }
        }
      },
      "put": {
        "tags": ["Todos"],
        "summary": "할일 수정 (UC-05)",
        "description": "할일 정보를 수정합니다. 소유자만 수정 가능합니다(BR-03). 요청에 포함된 필드만 업데이트됩니다. due_date와 start_date의 대소 관계는 항상 검증합니다(BR-08).",
        "operationId": "updateTodo",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" },
            "description": "수정할 할일 ID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "description": "수정할 필드만 포함. 미포함 필드는 기존 값 유지.",
                "properties": {
                  "title": {
                    "type": "string",
                    "maxLength": 200,
                    "description": "수정할 제목 (최대 200자)",
                    "example": "주간 보고서 작성 (수정)"
                  },
                  "description": {
                    "type": "string",
                    "maxLength": 1000,
                    "nullable": true,
                    "description": "수정할 설명 (최대 1000자)",
                    "example": "긴급 수정 필요"
                  },
                  "start_date": {
                    "type": "string",
                    "format": "date",
                    "description": "수정할 시작일 (YYYY-MM-DD)",
                    "example": "2026-05-13"
                  },
                  "due_date": {
                    "type": "string",
                    "format": "date",
                    "description": "수정할 종료예정일 (YYYY-MM-DD, start_date 이상)",
                    "example": "2026-05-15"
                  },
                  "category_id": {
                    "type": "string",
                    "format": "uuid",
                    "description": "수정할 카테고리 ID",
                    "example": "c1000001-0000-0000-0000-000000000002"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "할일 수정 성공 (updated_at 갱신됨)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Todo" }
              }
            }
          },
          "400": {
            "description": "유효성 오류",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "examples": {
                  "invalidDate": {
                    "summary": "날짜 오류",
                    "value": { "code": "TODO_INVALID_DATE", "message": "종료예정일은 시작일보다 이전일 수 없습니다" }
                  },
                  "validationError": {
                    "summary": "입력값 오류",
                    "value": { "code": "VALIDATION_ERROR", "message": "입력값을 확인해주세요" }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/401Unauthorized" },
          "403": { "$ref": "#/components/responses/403Forbidden" },
          "404": {
            "description": "할일 또는 카테고리 없음",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "examples": {
                  "todoNotFound": {
                    "summary": "할일 없음",
                    "value": { "code": "TODO_NOT_FOUND", "message": "할일을 찾을 수 없습니다" }
                  },
                  "categoryNotFound": {
                    "summary": "카테고리 없음",
                    "value": { "code": "CATEGORY_NOT_FOUND", "message": "카테고리를 찾을 수 없습니다" }
                  }
                }
              }
            }
          },
          "500": { "$ref": "#/components/responses/500InternalError" }
        }
      },
      "delete": {
        "tags": ["Todos"],
        "summary": "할일 삭제 (UC-06)",
        "description": "할일을 물리 삭제합니다. 소유자만 삭제 가능하며(BR-03) 삭제 후 복구할 수 없습니다. Soft Delete 미사용.",
        "operationId": "deleteTodo",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" },
            "description": "삭제할 할일 ID"
          }
        ],
        "responses": {
          "204": {
            "description": "할일 삭제 성공 (응답 본문 없음)"
