{
  "openapi": "3.0.3",
  "info": {
    "title": "TodoListApp API",
    "description": "할일 관리 웹앱 REST API. JWT 이중 토큰(Access Token 1h + Refresh Token 7d) 기반 인증. 모든 토큰은 응답 본문(JSON)으로 전달되며 쿠키를 사용하지 않습니다.",
    "version": "1.0.0",
    "contact": {
      "name": "TodoListApp"
    }
  },
  "servers": [
    {
      "url": "http://localhost:3000/api/v1",
      "description": "개발 서버"
    }
  ],
  "tags": [
    {
      "name": "Auth",
      "description": "회원가입 · 로그인 · 토큰 관리"
    },
    {
      "name": "Categories",
      "description": "카테고리 조회"
    },
    {
      "name": "Todos",
      "description": "할일 CRUD · 완료 토글 · 필터 조회"
    }
  ],
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Access Token을 Authorization 헤더에 포함합니다. 만료 시(1h) POST /auth/refresh로 갱신하세요."
      }
    },
    "schemas": {
      "User": {
        "type": "object",
        "description": "사용자 계정 정보 (password 필드는 응답에 포함되지 않습니다)",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "사용자 고유 식별자",
            "example": "a1b2c3d4-e5f6-7890-abcd-ef1234567890"
          },
          "email": {
            "type": "string",
            "format": "email",
            "maxLength": 255,
            "description": "이메일 주소 (로그인 ID, 중복 불가)",
            "example": "hong@example.com"
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 50,
            "description": "사용자 이름",
            "example": "홍길동"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "계정 생성 시각 (ISO 8601)",
            "example": "2026-05-13T09:00:00.000Z"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "계정 수정 시각 (ISO 8601)",
            "example": "2026-05-13T09:00:00.000Z"
          }
        },
        "required": ["id", "email", "name", "created_at", "updated_at"]
      },
      "Category": {
        "type": "object",
        "description": "카테고리. is_default=true이면 모든 사용자가 공유하는 기본 카테고리(user_id=null).",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "카테고리 고유 식별자",
            "example": "c1d2e3f4-1234-5678-abcd-aabbccddeeff"
          },
          "name": {
            "type": "string",
            "maxLength": 100,
            "description": "카테고리명",
            "example": "업무"
          },
          "is_default": {
            "type": "boolean",
            "description": "true = 시스템 기본 카테고리 (업무·개인·건강·쇼핑), false = 사용자 정의",
            "example": true
          },
          "user_id": {
            "type": "string",
            "format": "uuid",
            "nullable": true,
            "description": "소유 사용자 ID. null이면 기본 카테고리(모든 사용자 공유).",
            "example": null
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "생성 시각 (ISO 8601)",
            "example": "2026-05-13T00:00:00.000Z"
          }
        },
        "required": ["id", "name", "is_default", "user_id", "created_at"]
      },
      "Todo": {
        "type": "object",
        "description": "할일 항목",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "할일 고유 식별자",
            "example": "f1e2d3c4-b5a6-7890-1234-567890abcdef"
          },
          "user_id": {
            "type": "string",
            "format": "uuid",
            "description": "소유 사용자 ID",
            "example": "a1b2c3d4-e5f6-7890-abcd-ef1234567890"
          },
          "category_id": {
            "type": "string",
            "format": "uuid",
            "description": "카테고리 ID",
            "example": "c1d2e3f4-1234-5678-abcd-aabbccddeeff"
          },
          "title": {
            "type": "string",
            "maxLength": 200,
            "description": "할일 제목 (필수, 최대 200자)",
            "example": "주간 보고서 작성"
          },
          "description": {
            "type": "string",
            "maxLength": 1000,
            "nullable": true,
            "description": "할일 설명 (선택, 최대 1000자)",
            "example": "팀 전체 공유 필요"
          },
          "start_date": {
            "type": "string",
            "format": "date",
            "description": "시작일 (YYYY-MM-DD)",
            "example": "2026-05-13"
          },
          "due_date": {
            "type": "string",
            "format": "date",
            "description": "종료예정일 (YYYY-MM-DD, start_date 이상이어야 함 BR-08)",
            "example": "2026-05-14"
          },
          "is_completed": {
            "type": "boolean",
            "description": "완료 여부. 생성 시 false. PATCH /todos/:id/toggle로 전환 권장.",
            "example": false
          },
          "completed_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true,
            "description": "완료 처리 시각. 미완료이면 null, 완료 토글 시 NOW(), 미완료 복원 시 null (BR-09).",
            "example": null
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "생성 시각 (ISO 8601)",
            "example": "2026-05-13T10:00:00.000Z"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "최종 수정 시각 (ISO 8601)",
            "example": "2026-05-13T10:00:00.000Z"
          }
        },
        "required": [
          "id", "user_id", "category_id", "title",
          "start_date", "due_date", "is_completed",
          "completed_at", "created_at", "updated_at"
        ]
      },
      "AuthResponse": {
        "type": "object",
        "description": "로그인 성공 응답. 두 토큰 모두 JSON 본문으로 반환 (쿠키 미사용).",
        "properties": {
          "accessToken": {
            "type": "string",
            "description": "Access Token (JWT, 유효기간 1h). Authorization: Bearer 헤더로 사용.",
            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
          },
          "refreshToken": {
            "type": "string",
            "description": "Refresh Token (JWT, 유효기간 7d). POST /auth/refresh 요청 본문으로 사용.",
            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
          }
        },
        "required": ["accessToken", "refreshToken"]
      },
      "RefreshResponse": {
        "type": "object",
        "description": "Access Token 갱신 응답",
        "properties": {
          "accessToken": {
            "type": "string",
            "description": "새로 발급된 Access Token (JWT, 유효기간 1h)",
            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
          }
        },
        "required": ["accessToken"]
      },
      "PaginatedTodos": {
        "type": "object",
        "description": "페이지네이션이 포함된 할일 목록 응답",
        "properties": {
          "todos": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Todo"
            },
            "description": "할일 배열 (due_date ASC 정렬)"
          },
          "pagination": {
            "type": "object",
            "properties": {
              "page": {
                "type": "integer",
                "description": "현재 페이지 번호 (1-indexed)",
                "example": 1
              },
              "limit": {
                "type": "integer",
                "description": "페이지당 항목 수",
                "example": 20
              },
              "total": {
                "type": "integer",
                "description": "필터 조건에 맞는 전체 항목 수",
                "example": 3
              }
            },
            "required": ["page", "limit", "total"]
          }
        },
        "required": ["todos", "pagination"]
      },
      "ErrorResponse": {
        "type": "object",
        "description": "에러 응답 (모든 에러에 공통 사용)",
        "properties": {
          "code": {
            "type": "string",
            "description": "에러 코드 문자열",
            "enum": [
              "AUTH_INVALID_CREDENTIALS",
              "AUTH_EMAIL_DUPLICATE",
              "AUTH_TOKEN_EXPIRED",
              "AUTH_UNAUTHORIZED",
              "TODO_NOT_FOUND",
              "TODO_FORBIDDEN",
              "TODO_INVALID_DATE",
              "CATEGORY_NOT_FOUND",
              "CATEGORY_IN_USE",
              "VALIDATION_ERROR",
              "INTERNAL_SERVER_ERROR"
            ],
            "example": "AUTH_INVALID_CREDENTIALS"
          },
          "message": {
            "type": "string",
            "description": "사용자 친화적 한국어 메시지",
            "example": "이메일 또는 비밀번호가 올바르지 않습니다"
          }
        },
        "required": ["code", "message"]
      }
    },
    "responses": {
      "401Unauthorized": {
        "description": "인증 실패 — 토큰 없음 또는 유효하지 않음",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" },
            "examples": {
              "noToken": {
                "summary": "토큰 없음",
                "value": { "code": "AUTH_UNAUTHORIZED", "message": "로그인이 필요합니다" }
              },
              "tokenExpired": {
                "summary": "토큰 만료",
                "value": { "code": "AUTH_TOKEN_EXPIRED", "message": "인증이 만료되었습니다. 다시 로그인해주세요" }
              }
            }
          }
        }
      },
      "403Forbidden": {
        "description": "권한 없음 — 다른 사용자의 리소스 접근 시도",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" },
            "example": { "code": "TODO_FORBIDDEN", "message": "접근 권한이 없습니다" }
          }
        }
      },
      "500InternalError": {
        "description": "서버 내부 오류",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" },
            "example": { "code": "INTERNAL_SERVER_ERROR", "message": "일시적인 오류가 발생했습니다. 잠시 후 다시 시도해주세요" }
          }
        }
      }
    }
  },
  "paths": {
    "/auth/register": {
      "post": {
        "tags": ["Auth"],
        "summary": "회원가입 (UC-01)",
        "description": "이메일·비밀번호·이름으로 계정을 생성합니다. 성공 시 4개의 기본 카테고리(업무·개인·건강·쇼핑)에 자동으로 접근 권한이 부여됩니다. 비밀번호는 bcrypt(saltRounds≥12)로 해시 저장되며 응답에 포함되지 않습니다.",
        "operationId": "register",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password", "name"],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email",
                    "description": "이메일 (RFC 5322 형식, 중복 불가)",
                    "example": "hong@example.com"
                  },
                  "password": {
                    "type": "string",
                    "minLength": 8,
                    "description": "비밀번호 (최소 8자, 영문+숫자 조합 필수)",
                    "example": "pass1234"
                  },
                  "name": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 50,
                    "description": "사용자 이름 (1~50자)",
                    "example": "홍길동"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "회원가입 성공",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/User" },
                "example": {
                  "id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
                  "email": "hong@example.com",
                  "name": "홍길동",
                  "created_at": "2026-05-13T09:00:00.000Z",
                  "updated_at": "2026-05-13T09:00:00.000Z"
                }
              }
            }
          },
          "400": {
            "description": "입력값 유효성 오류",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "example": { "code": "VALIDATION_ERROR", "message": "입력값을 확인해주세요" }
              }
            }
          },
          "409": {
            "description": "이메일 중복",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "example": { "code": "AUTH_EMAIL_DUPLICATE", "message": "이미 사용 중인 이메일입니다" }
              }
            }
          },
          "500": { "$ref": "#/components/responses/500InternalError" }
        }
      }
    },
    "/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "로그인 (UC-02)",
        "description": "이메일·비밀번호로 인증하고 Access Token(1h)과 Refresh Token(7d)을 JSON 본문으로 반환합니다. 두 토큰 모두 쿠키가 아닌 응답 본문에 포함됩니다.",
        "operationId": "login",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email",
                    "description": "등록된 이메일",
                    "example": "hong@example.com"
                  },
                  "password": {
                    "type": "string",
                    "description": "비밀번호",
                    "example": "pass1234"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "로그인 성공 — Access Token + Refresh Token 반환",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AuthResponse" }
              }
            }
          },
          "400": {
            "description": "입력값 유효성 오류",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "example": { "code": "VALIDATION_ERROR", "message": "입력값을 확인해주세요" }
              }
            }
          },
          "401": {
            "description": "인증 실패 (이메일 미존재 또는 비밀번호 불일치, 단일 오류 메시지)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "example": { "code": "AUTH_INVALID_CREDENTIALS", "message": "이메일 또는 비밀번호가 올바르지 않습니다" }
              }
            }
          },
          "500": { "$ref": "#/components/responses/500InternalError" }
        }
      }
    },
    "/auth/logout": {
      "post": {
        "tags": ["Auth"],
        "summary": "로그아웃",
        "description": "Refresh Token을 서버에 전달하여 무효화합니다. Access Token은 Authorization 헤더로 사용자를 식별하고, Refresh Token은 요청 본문으로 전달합니다.",
        "operationId": "logout",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["refreshToken"],
                "properties": {
                  "refreshToken": {
                    "type": "string",
                    "description": "무효화할 Refresh Token",
                    "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "로그아웃 성공",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "example": {}
                }
              }
            }
          },
          "400": {
            "description": "입력값 유효성 오류",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "example": { "code": "VALIDATION_ERROR", "message": "입력값을 확인해주세요" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/401Unauthorized" },
          "500": { "$ref": "#/components/responses/500InternalError" }
        }
      }
    },
    "/auth/refresh": {
      "post": {
        "tags": ["Auth"],
        "summary": "Access Token 재발급 (SCN-09)",
        "description": "유효한 Refresh Token으로 새 Access Token을 발급합니다. Access Token 만료(401 AUTH_TOKEN_EXPIRED) 시 클라이언트 axios 인터셉터가 자동으로 호출합니다. Authorization 헤더 불필요.",
        "operationId": "refreshToken",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["refreshToken"],
                "properties": {
                  "refreshToken": {
                    "type": "string",
                    "description": "유효한 Refresh Token (7일 이내 발급)",
                    "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Access Token 재발급 성공",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/RefreshResponse" }
              }
            }
          },
          "400": {
            "description": "입력값 유효성 오류",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "example": { "code": "VALIDATION_ERROR", "message": "입력값을 확인해주세요" }
              }
            }
          },
          "401": {
            "description": "Refresh Token 만료 또는 유효하지 않음 → 재로그인 필요",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "examples": {
                  "expired": {
                    "summary": "RT 만료",
                    "value": { "code": "AUTH_TOKEN_EXPIRED", "message": "인증이 만료되었습니다. 다시 로그인해주세요" }
                  },
                  "invalid": {
                    "summary": "RT 무효",
                    "value": { "code": "AUTH_UNAUTHORIZED", "message": "로그인이 필요합니다" }
                  }
                }
              }
            }
          },
          "500": { "$ref": "#/components/responses/500InternalError" }
        }
      }
    },
    "/categories": {
      "get": {
        "tags": ["Categories"],
        "summary": "카테고리 목록 조회 (BR-05)",
        "description": "인증된 사용자가 접근 가능한 카테고리 목록을 반환합니다. MVP에서는 4개의 기본 카테고리(업무·개인·건강·쇼핑)를 반환합니다. 기본 카테고리는 is_default=true, user_id=null이며 모든 사용자가 공유합니다.",
        "operationId": "getCategories",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": {
            "description": "카테고리 목록 조회 성공",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Category" }
                },
                "example": [
                  { "id": "c1000001-0000-0000-0000-000000000001", "name": "업무", "is_default": true, "user_id": null, "created_at": "2026-05-13T00:00:00.000Z" },
                  { "id": "c1000001-0000-0000-0000-000000000002", "name": "개인", "is_default": true, "user_id": null, "created_at": "2026-05-13T00:00:00.000Z" },
                  { "id": "c1000001-0000-0000-0000-000000000003", "name": "건강", "is_default": true, "user_id": null, "created_at": "2026-05-13T00:00:00.000Z" },
                  { "id": "c1000001-0000-0000-0000-000000000004", "name": "쇼핑", "is_default": true, "user_id": null, "created_at": "2026-05-13T00:00:00.000Z" }
                ]
              }
            }
          },
          "401": { "$ref": "#/components/responses/401Unauthorized" },
          "500": { "$ref": "#/components/responses/500InternalError" }
        }
      }
    },
    "/todos": {
      "get": {
        "tags": ["Todos"],
        "summary": "할일 목록 조회 · 필터 (UC-08)",
        "description": "인증된 사용자의 할일 목록을 조회합니다. 카테고리·완료여부·일정상태 필터를 조합할 수 있으며 기본 정렬은 due_date ASC입니다. schedule_status=overdue는 due_date < 오늘 AND is_completed=false인 항목만 반환합니다.",
        "operationId": "getTodos",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "minimum": 1, "default": 1 },
            "description": "페이지 번호 (1-indexed)"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "minimum": 1, "maximum": 20, "default": 20 },
            "description": "페이지당 항목 수 (최대 20)"
          },
          {
            "name": "category_id",
            "in": "query",
            "required": false,
            "schema": { "type": "string", "format": "uuid" },
            "description": "카테고리 ID로 필터"
          },
          {
            "name": "is_completed",
            "in": "query",
            "required": false,
            "schema": { "type": "boolean" },
            "description": "완료 여부로 필터 (true=완료만, false=미완료만)"
          },
          {
            "name": "schedule_status",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": ["ongoing", "overdue"]
            },
            "description": "일정 상태 필터. overdue: due_date < 오늘 AND is_completed=false / ongoing: due_date >= 오늘 OR is_completed=true"
          }
        ],
        "responses": {
          "200": {
            "description": "할일 목록 조회 성공",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PaginatedTodos" },
                "example": {
                  "todos": [
                    {
                      "id": "f1e2d3c4-b5a6-7890-1234-567890abcdef",
                      "user_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
                      "category_id": "c1000001-0000-0000-0000-000000000001",
                      "title": "주간 보고서 작성",
                      "description": "팀 전체 공유 필요",
                      "start_date": "2026-05-13",
                      "due_date": "2026-05-14",
                      "is_completed": false,
                      "completed_at": null,
                      "created_at": "2026-05-13T10:00:00.000Z",
                      "updated_at": "2026-05-13T10:00:00.000Z"
                    }
                  ],
                  "pagination": { "page": 1, "limit": 20, "total": 1 }
                }
              }
            }
          },
          "400": {
            "description": "쿼리 파라미터 유효성 오류",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "example": { "code": "VALIDATION_ERROR", "message": "입력값을 확인해주세요" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/401Unauthorized" },
          "500": { "$ref": "#/components/responses/500InternalError" }
        }
      },
      "post": {
        "tags": ["Todos"],
        "summary": "할일 등록 (UC-04)",
        "description": "새 할일을 생성합니다. due_date는 start_date 이상이어야 합니다(BR-08). category_id는 사용자가 접근 가능한 카테고리여야 합니다(BR-07). 생성 시 is_completed=false, completed_at=null로 초기화됩니다.",
        "operationId": "createTodo",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["title", "start_date", "due_date", "category_id"],
                "properties": {
                  "title": {
                    "type": "string",
                    "maxLength": 200,
                    "description": "할일 제목 (필수, 최대 200자)",
                    "example": "주간 보고서 작성"
                  },
                  "description": {
                    "type": "string",
                    "maxLength": 1000,
                    "nullable": true,
                    "description": "할일 설명 (선택, 최대 1000자)",
                    "example": "팀 전체 공유 필요"
                  },
                  "start_date": {
                    "type": "string",
                    "format": "date",
                    "description": "시작일 (YYYY-MM-DD, 필수)",
                    "example": "2026-05-13"
                  },
                  "due_date": {
                    "type": "string",
                    "format": "date",
                    "description": "종료예정일 (YYYY-MM-DD, 필수, start_date 이상)",
                    "example": "2026-05-14"
                  },
                  "category_id": {
                    "type": "string",
                    "format": "uuid",
                    "description": "카테고리 ID (필수, 사용자 접근 가능한 카테고리)",
                    "example": "c1000001-0000-0000-0000-000000000001"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "할일 등록 성공",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Todo" },
                "example": {
                  "id": "f1e2d3c4-b5a6-7890-1234-567890abcdef",
                  "user_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
                  "category_id": "c1000001-0000-0000-0000-000000000001",
                  "title": "주간 보고서 작성",
                  "description": "팀 전체 공유 필요",
                  "start_date": "2026-05-13",
                  "due_date": "2026-05-14",
                  "is_completed": false,
                  "completed_at": null,
                  "created_at": "2026-05-13T10:00:00.000Z",
                  "updated_at": "2026-05-13T10:00:00.000Z"
                }
              }
            }
          },
          "400": {
            "description": "유효성 오류",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "examples": {
                  "invalidDate": {
                    "summary": "날짜 오류 (BR-08)",
                    "value": { "code": "TODO_INVALID_DATE", "message": "종료예정일은 시작일보다 이전일 수 없습니다" }
                  },
                  "validationError": {
                    "summary": "입력값 오류",
                    "value": { "code": "VALIDATION_ERROR", "message": "입력값을 확인해주세요" }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/401Unauthorized" },
          "404": {
            "description": "카테고리 없음 또는 접근 불가",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "example": { "code": "CATEGORY_NOT_FOUND", "message": "카테고리를 찾을 수 없습니다" }
              }
            }
          },
          "500": { "$ref": "#/components/responses/500InternalError" }
        }
      }
    },
    "/todos/{id}": {
      "get": {
        "tags": ["Todos"],
        "summary": "할일 단건 조회",
        "description": "ID로 단일 할일을 조회합니다. 소유자만 조회 가능합니다(BR-03).",
        "operationId": "getTodoById",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
